<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Adithi Uday Pai</title>
  <style>

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: Arial, sans-serif;
      background-color: #f0f4f8;
      color: #333;
    }

    /* ── NAVBAR ── */
    nav {
      background-color: #0b2545;
      padding: 16px 40px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    nav .logo {
      color: #ffffff;
      font-size: 20px;
      font-weight: bold;
    }

    nav ul {
      list-style: none;
      display: flex;
      gap: 24px;
    }

    nav ul li a {
      color: #a8c8d8;
      text-decoration: none;
      font-size: 15px;
    }

    nav ul li a:hover {
      color: #f0a500;
    }

    /* ── HERO SECTION ── */
    .hero {
      display: flex;
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      padding: 80px 60px;
      gap: 60px;
      min-height: calc(100vh - 56px);
    }

    /* Left: Text */
    .hero-text {
      flex: 1;
    }

    .hero-text h1 {
      font-size: 48px;
      color: #0b2545;
      line-height: 1.2;
      margin-bottom: 16px;
    }

    .hero-text h1 span {
      color: #1b7a8a;
    }

    .hero-text p {
      font-size: 17px;
      color: #555;
      line-height: 1.8;
      margin-bottom: 30px;
      max-width: 480px;
    }

    .hero-buttons {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
    }

    .btn-primary {
      background-color: #0b2545;
      color: #ffffff;
      padding: 12px 28px;
      border-radius: 6px;
      font-size: 15px;
      text-decoration: none;
    }

    .btn-primary:hover { background-color: #1b7a8a; }

    .btn-secondary {
      background-color: transparent;
      color: #0b2545;
      padding: 12px 28px;
      border: 2px solid #0b2545;
      border-radius: 6px;
      font-size: 15px;
      text-decoration: none;
    }

    .btn-secondary:hover {
      background-color: #0b2545;
      color: #fff;
    }

    /* Right: Image card */
    .hero-image {
      flex: 1;
      display: flex;
      justify-content: center;
    }

    .image-card {
      width: 340px;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 8px 32px rgba(11, 37, 69, 0.18);
      border: 3px solid #1b7a8a;
    }

    .image-card img {
      width: 100%;
      height: 380px;
      object-fit: cover;
      object-position: top;
      display: block;
    }

    .image-card-footer {
      background-color: #0b2545;
      padding: 14px 18px;
      text-align: center;
    }

    .image-card-footer p {
      color: #a8c8d8;
      font-size: 13px;
      margin: 0;
    }

    .image-card-footer strong {
      color: #f0a500;
      font-size: 15px;
      display: block;
      margin-bottom: 2px;
    }

    /* ── STATS BAR ── */
    .stats {
      display: flex;
      justify-content: center;
      gap: 60px;
      background-color: #0b2545;
      padding: 30px 40px;
      flex-wrap: wrap;
    }

    .stat {
      text-align: center;
      color: #ffffff;
    }

    .stat h2 {
      font-size: 32px;
      color: #f0a500;
    }

    .stat p {
      font-size: 14px;
      color: #a8c8d8;
      margin-top: 4px;
    }

    /* ── MOBILE ── */
    @media (max-width: 768px) {

      nav { padding: 14px 20px; }
      nav ul { gap: 14px; }

      .hero {
        flex-direction: column;
        text-align: center;
        padding: 50px 24px;
      }

      .hero-text h1 { font-size: 32px; }
      .hero-text p  { font-size: 15px; }

      .hero-buttons { justify-content: center; }

      .image-card { width: 280px; }
      .image-card img { height: 300px; }

      .stats { gap: 30px; padding: 24px 20px; }
      .stat h2 { font-size: 24px; }
    }

  </style>
</head>
<body>

  <!-- NAVBAR -->
  <nav>
    <div class="logo">Adithi Uday Pai</div>
    <ul>
      <li><a href="#">Home</a></li>
      <li><a href="#">Projects</a></li>
      <li><a href="#">Contact</a></li>
    </ul>
  </nav>

  <!-- HERO -->
  <section class="hero">

    <div class="hero-text">
      <h1>Hi, I'm <span>Adithi</span> 👋</h1>
      <p>
        Information Science and Engineering student at Gogte Institute of Technology, Belgaum.
        Passionate about Full-Stack Development, Cloud Computing, and Generative AI.
      </p>
      <div class="hero-buttons">
        <a href="mailto:adithiudaypai24@gmail.com" class="btn-primary">Contact Me</a>
        <a href="https://linkedin.com/in/adithi-uday-pai-4b056b25b" target="_blank" class="btn-secondary">LinkedIn</a>
      </div>
    </div>

    <div class="hero-image">
      <div class="image-card">
        <img src="https://images.unsplash.com/photo-1573496359142-b8d87734a5a2?w=400&q=80" alt="Adithi Uday Pai" />
        <div class="image-card-footer">
          <strong>Adithi Uday Pai</strong>
          <p>ISE Student · GIT Belgaum</p>
        </div>
      </div>
    </div>

  </section>

  <!-- STATS -->
  <div class="stats">
    <div class="stat"><h2>8.9</h2><p>CGPA</p></div>
    <div class="stat"><h2>4+</h2><p>Projects</p></div>
    <div class="stat"><h2>4</h2><p>Certifications</p></div>
    <div class="stat"><h2>10+</h2><p>Years in Music</p></div>
  </div>

</body>
</html>
