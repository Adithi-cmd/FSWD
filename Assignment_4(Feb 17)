<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Adithi Uday Pai</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet"/>
  <style>
    /* ── VARIABLES ── */
    :root {
      --navy:   #0b2545;
      --teal:   #1b7a8a;
      --sky:    #e8f4f8;
      --white:  #ffffff;
      --text:   #2d2d2d;
      --muted:  #6b7280;
      --border: #d0e8ee;
      --accent: #f0a500;
    }

    /* ── RESET ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Lato', sans-serif;
      font-weight: 300;
      background: var(--sky);
      color: var(--text);
      min-height: 100vh;
    }

    /* ── HEADER BANNER ── */
    .header {
      background: var(--navy);
      padding: 48px 40px 40px;
      display: flex;
      align-items: center;
      gap: 36px;
    }

    .header img {
      width: 130px;
      height: 130px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid var(--accent);
      flex-shrink: 0;
    }

    .header-info h1 {
      font-family: 'Playfair Display', serif;
      font-size: 40px;
      color: var(--white);
      letter-spacing: -0.5px;
      margin-bottom: 10px;
    }

    .header-info h1 span { color: var(--accent); }

    .header-meta {
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .header-meta a,
    .header-meta p {
      font-size: 14px;
      color: #a8c8d8;
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .header-meta a:hover { color: var(--accent); }

    /* ── MAIN WRAPPER ── */
    .wrapper {
      max-width: 860px;
      margin: 0 auto;
      padding: 40px 24px 60px;
      display: flex;
      flex-direction: column;
      gap: 32px;
    }

    /* ── CARD ── */
    .card {
      background: var(--white);
      border-radius: 12px;
      border: 1px solid var(--border);
      padding: 32px 36px;
      animation: fadeUp 0.5s ease both;
    }

    .card:nth-child(1) { animation-delay: 0.05s; }
    .card:nth-child(2) { animation-delay: 0.1s;  }
    .card:nth-child(3) { animation-delay: 0.15s; }
    .card:nth-child(4) { animation-delay: 0.2s;  }
    .card:nth-child(5) { animation-delay: 0.25s; }
    .card:nth-child(6) { animation-delay: 0.3s;  }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ── SECTION TITLE ── */
    h2 {
      font-family: 'Playfair Display', serif;
      font-size: 22px;
      color: var(--navy);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    h2::after {
      content: '';
      flex: 1;
      height: 2px;
      background: linear-gradient(to right, var(--teal), transparent);
      border-radius: 2px;
    }

    /* ── ABOUT ── */
    .about-text {
      font-size: 15px;
      line-height: 1.85;
      color: #444;
    }

    /* ── EDUCATION LIST ── */
    .edu-list { list-style: none; display: flex; flex-direction: column; gap: 14px; }

    .edu-list li {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 14px 16px;
      border-radius: 8px;
      background: var(--sky);
      border-left: 4px solid var(--teal);
      font-size: 14px;
      line-height: 1.6;
    }

    .edu-list li strong { color: var(--navy); display: block; font-size: 15px; }

    /* ── SKILLS GRID ── */
    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
    }

    .skill-pill {
      background: var(--sky);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 10px 14px;
      font-size: 13px;
      color: var(--navy);
      font-weight: 400;
    }

    .skill-pill span {
      display: block;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--teal);
      margin-bottom: 4px;
      font-weight: 700;
    }

    /* ── PROJECTS ── */
    .project-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .project-card {
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 18px 20px;
      transition: border-color 0.2s, transform 0.2s;
    }

    .project-card:hover {
      border-color: var(--teal);
      transform: translateY(-2px);
    }

    .project-card h3 {
      font-family: 'Playfair Display', serif;
      font-size: 16px;
      color: var(--navy);
      margin-bottom: 6px;
    }

    .project-card p {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.6;
    }

    /* ── HOBBIES ── */
    .hobby-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }

    .hobby-list li {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 14px;
      padding: 10px 14px;
      border-radius: 8px;
      background: var(--sky);
      border: 1px solid var(--border);
      color: var(--text);
    }

    .hobby-icon {
      font-size: 18px;
      width: 32px;
      text-align: center;
      flex-shrink: 0;
    }

    /* ── LINKS ── */
    .links-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 12px;
    }

    .links-grid a {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 12px 16px;
      border-radius: 8px;
      background: var(--navy);
      color: #a8c8d8;
      text-decoration: none;
      font-size: 13px;
      font-weight: 400;
      transition: background 0.2s, color 0.2s;
    }

    .links-grid a:hover { background: var(--teal); color: var(--white); }

    .links-grid a::before { content: '↗'; font-size: 12px; color: var(--accent); }

    /* ── FOOTER ── */
    footer {
      text-align: center;
      font-size: 12px;
      color: var(--muted);
      padding: 0 0 40px;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .header { flex-direction: column; text-align: center; padding: 36px 24px; }
      .header-meta { align-items: center; }
      .project-grid { grid-template-columns: 1fr; }
      .card { padding: 24px 20px; }
    }
  </style>
</head>
